# Copy to .env and fill in. Never commit .env.
OPENAI_API_KEY=sk-...

# Supabase (created later, in build step 2)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# WhatsApp Cloud API (Meta developer test number)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Twilio sandbox fallback (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# base inbox for per-seller plus-address aliases (services/email_alias.py)
KARIGAR_EMAIL_BASE=karigar.sellers@gmail.com
